#!/bin/sh
set -eu

state_dir="${XDG_CONFIG_HOME:-$HOME/.config}/obsidian"
state_file="$state_dir/welcome-complete"
mkdir -p "$state_dir"

if [ -f "$state_file" ]; then
  exit 0
fi

if command -v zenity >/dev/null 2>&1; then
  zenity --info --title='Welcome to Obsidian Linux' --text='Welcome to Obsidian Linux. Open Obsidian Center from the host desktop for system setup and management.'
else
  printf '%s\n' 'Welcome to Obsidian Linux. Open Obsidian Center from the host desktop for system setup and management.'
fi

date -u +'%Y-%m-%dT%H:%M:%SZ' > "$state_file"
