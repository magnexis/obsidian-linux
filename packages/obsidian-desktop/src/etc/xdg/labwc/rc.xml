<?xml version="1.0" encoding="UTF-8"?>
<labwc_config>
  <core>
    <gap>0</gap>
  </core>
  <keyboard>
    <default />
    <keybind key="W-Return">
      <action name="Execute" command="foot" />
    </keybind>
    <keybind key="W-d">
      <action name="Execute" command="obsidian-launcher" />
    </keybind>
    <keybind key="W-e">
      <action name="Execute" command="thunar" />
    </keybind>
    <keybind key="W-q">
      <action name="Close" />
    </keybind>
    <keybind key="W-l">
      <action name="Execute" command="swaylock -f -c 0B0D10" />
    </keybind>
    <keybind key="W-S-r">
      <action name="Reconfigure" />
    </keybind>
    <keybind key="Print">
      <action name="Execute" command="sh -c 'grim -g \"$(slurp)\" ~/Pictures/$(date +%Y%m%d-%H%M%S).png'" />
    </keybind>
    <keybind key="A-Tab">
      <action name="NextWindow" />
    </keybind>
  </keyboard>
</labwc_config>
